{
  "name": "piggability-study-tool",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Piggability Study Tool — Module 0 of a pipeline-integrity platform. Screening study for in-line inspection (ILI) tool selection.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
