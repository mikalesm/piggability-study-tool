# The app runs fully without these. Set them to enable the Supabase (Postgres) repo.
# When unset, persistence falls back to localStorage.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: tenant id used by the Supabase repo (multi-tenant RLS by tenant_id).
# Anonymous access (no auth) resolves to the 'default' tenant.
VITE_TENANT_ID=default

# Optional: table-name prefix. Leave empty for a DEDICATED Supabase project
# (apply migration 0001_init.sql). Set to pgy_ to share an EXISTING project
# alongside another app (apply 0002_shared_prefixed.sql).
VITE_SUPABASE_TABLE_PREFIX=

# Optional: Vite base path. Defaults to /piggability/ for GitHub Pages.
# Set to / for root hosting or local-only use.
# VITE_BASE=/
