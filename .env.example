# The app runs fully without these. Set both to enable the Supabase (Postgres) repo.
# When unset, persistence falls back to localStorage.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: tenant id used by the Supabase repo (multi-tenant RLS by tenant_id).
VITE_TENANT_ID=

# Optional: Vite base path. Defaults to /piggability/ for GitHub Pages.
# Set to / for root hosting or local-only use.
# VITE_BASE=/
